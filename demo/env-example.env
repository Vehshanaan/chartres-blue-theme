# =============================================================================
# CATHEDRAL_ENV — Chartres Cathedral Environment Configuration
# This file is used by the cathedral management system.
# Lines beginning with # are comments.
# =============================================================================

# --- General Settings ---
CATHEDRAL_NAME=Chartres Cathedral
CATHEDRAL_CITY=Chartres
CATHEDRAL_COUNTRY=France
YEAR_BUILT=1260
ARCHITECTURAL_STYLE=High Gothic
UNESCO_SITE=true

# --- Dimensions (meters) ---
NAVE_HEIGHT=36.5
NAVE_LENGTH=130.2
TOWER_NORTH=113.0
TOWER_SOUTH=105.0

# --- Visitor Information ---
ENTRY_FEE=0

# GUIDE_NAME must be wrapped in quotes if it contains spaces
GUIDE_NAME="Malcolm Miller"
GUIDE_LANGUAGE=en
GUIDE_YEARS="1956—2023"

# --- Stained Glass Configuration ---
DOMINANT_COLOR=Chartres blue
COLORS_LIST="blue, red, gold, green, purple, white"
WINDOW_COUNT=176
ROSE_WINDOW_DIAMETER=10.5
OLDEST_PANEL_YEAR=1145

# --- Multi-line value: the famous description of Chartres blue ---
CHARTRE_BLUE_DESCRIPTION="A deep, luminous cobalt blue\
achieved by high cobalt oxide content in the glass.\
Perfected by 12th-century glaziers; the formula remains\
a closely guarded trade secret."

# --- Security & Access ---
CRYPT_ACCESSIBLE=true
CRYPT_DEPTH_M=8.5
CRYPT_BUILDER=Fulbert
export TOWER_CLIMB_FEE=8.50
export PHOTOGRAPHY_ALLOWED=false
export MAX_GROUP_SIZE=25

# --- API / Integration ---
API_BASE_URL=https://api.chartres-cathedral.fr/v1
API_TIMEOUT_SECONDS=30
LOGGING_LEVEL=info

# --- Maintenance Flags ---
RESTORATION_IN_PROGRESS=false
LAST_RESTORATION_YEAR=2019
SCAFFOLDING_ACTIVE=false

# --- Database (commented out; not used in this config) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cathedral_glass

# --- Paths ---
GLASS_ARCHIVE_PATH="C:\Chartres\StainedGlass\Archive"
STONEWORK_BLUEPRINTS=/var/cathedral/blueprints/stonework
LOG_DIR=/var/log/cathedral
TEMP_DIR=/tmp/cathedral

# --- Feature Flags ---
FF_VIRTUAL_TOUR_ENABLED=true
FF_NIGHT_VISIT_ENABLED=false
FF_ORGAN_CONCERT_ALERTS=true
FF_CRYPT_SENSOR_NETWORK=true

# =============================================================================
# End of cathedral environment configuration
# =============================================================================
