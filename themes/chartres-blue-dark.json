  "tokenColors": [
    {
      "scope": ["comment", "comment.line", "comment.block", "comment.line.double-slash", "comment.block.documentation"],
      "settings": { "foreground": "#6B7E9E", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.quoted.double", "string.quoted.single", "string.template"],
      "settings": { "foreground": "#7BB896" }
    },
    {
      "scope": ["string.regexp"],
      "settings": { "foreground": "#C9A84C" }
    },
    {
      "scope": ["string.quoted.docstring", "string.quoted.other.multiline"],
      "settings": { "foreground": "#7BB896", "fontStyle": "italic" }
    },
    {
      "scope": ["keyword", "keyword.control", "keyword.operator.word", "keyword.other"],
      "settings": { "foreground": "#80B0F0" }
    },
    {
      "scope": ["keyword.control.import", "keyword.control.export", "keyword.control.from"],
      "settings": { "foreground": "#80B0F0", "fontStyle": "italic" }
    },
    {
      "scope": ["storage", "storage.type", "storage.type.class", "storage.type.function", "storage.type.interface", "storage.type.enum"],
      "settings": { "foreground": "#80B0F0" }
    },
    {
      "scope": ["storage.modifier", "storage.modifier.abstract", "storage.modifier.static", "storage.modifier.public", "storage.modifier.private", "storage.modifier.protected", "storage.modifier.async", "storage.modifier.const"],
      "settings": { "foreground": "#8892A8" }
    },
    {
      "scope": ["constant", "constant.language", "constant.numeric", "constant.character", "constant.other"],
      "settings": { "foreground": "#D4A047" }
    },
    {
      "scope": ["constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#D4A047" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#D6E2F0" }
    },
    {
      "scope": ["variable.language", "variable.language.this", "variable.language.super", "variable.language.self"],
      "settings": { "foreground": "#B8862D" }
    },
    {
      "scope": ["variable.parameter", "variable.parameter.function"],
      "settings": { "foreground": "#D4E2F5" }
    },
    {
      "scope": ["entity.name.function", "entity.name.function.constructor"],
      "settings": { "foreground": "#C9A84C" }
    },
    {
      "scope": ["entity.name.type", "entity.name.type.class", "entity.name.type.interface", "entity.name.type.enum", "entity.name.type.type-alias"],
      "settings": { "foreground": "#5A9ABF" }
    },
    {
      "scope": ["entity.name.class"],
      "settings": { "foreground": "#5A9ABF" }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": { "foreground": "#5A9ABF" }
    },
    {
      "scope": ["entity.name.tag", "entity.name.tag.html", "entity.name.tag.xml"],
      "settings": { "foreground": "#4070D0" }
    },
    {
      "scope": ["entity.other.attribute-name", "entity.other.attribute-name.html", "entity.other.attribute-name.css"],
      "settings": { "foreground": "#B8862D" }
    },
    {
      "scope": ["support.function", "support.function.console", "support.function.DOM", "support.function.builtin"],
      "settings": { "foreground": "#80B0F0" }
    },
    {
      "scope": ["support.class", "support.type", "support.type.builtin"],
      "settings": { "foreground": "#5A9ABF" }
    },
    {
      "scope": ["punctuation", "punctuation.definition", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#6B7E9E" }
    },
    {
      "scope": ["punctuation.definition.tag", "punctuation.definition.tag.html", "punctuation.definition.tag.xml"],
      "settings": { "foreground": "#556888" }
    },
    {
      "scope": ["punctuation.definition.comment"],
      "settings": { "foreground": "#6B7E9E", "fontStyle": "italic" }
    },
    {
      "scope": ["punctuation.definition.string", "punctuation.definition.string.begin", "punctuation.definition.string.end"],
      "settings": { "foreground": "#7BB896" }
    },
    {
      "scope": ["meta.tag", "meta.tag.html", "meta.tag.xml"],
      "settings": { "foreground": "#8892A8" }
    },
    {
      "scope": ["meta.array", "meta.object", "meta.block"],
      "settings": { "foreground": "#D6E2F0" }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": { "foreground": "#C7364A", "fontStyle": "underline" }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": { "foreground": "#9B1B30", "fontStyle": "underline" }
    },
    {
      "scope": ["markup.heading", "markup.heading.markdown"],
      "settings": { "foreground": "#80B0F0", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.list", "markup.list.markdown"],
      "settings": { "foreground": "#C9A84C" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "foreground": "#D6E2F0", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "foreground": "#D6E2F0", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#7BB896" }
    },
    {
      "scope": ["support.type.property-name.css", "support.type.property-name"],
      "settings": { "foreground": "#D6E2F0" }
    },
    {
      "scope": ["entity.name.tag.css", "entity.name.tag.reference.css", "entity.other.attribute-name.class.css", "entity.other.attribute-name.id.css"],
      "settings": { "foreground": "#C9A84C" }
    },
    {
      "scope": ["string.template.js", "string.template.ts", "string.template.jsx", "string.template.tsx"],
      "settings": { "foreground": "#7BB896" }
    },
    {
      "scope": ["punctuation.definition.template-expression"],
      "settings": { "foreground": "#8892A8" }
    }
  ],
  "semanticTokenColors": {
    "class": "#5A9ABF",
    "class.defaultLibrary": "#5A9ABF",
    "interface": "#5A9ABF",
    "enum": "#5A9ABF",
    "type": "#5A9ABF",
    "typeAlias": "#5A9ABF",
    "namespace": "#5A9ABF",
    "function": "#C9A84C",
    "function.defaultLibrary": "#80B0F0",
    "method": "#C9A84C",
    "method.defaultLibrary": "#80B0F0",
    "property": "#D6E2F0",
    "variable": "#D6E2F0",
    "variable.readonly": "#D4A047",
    "variable.defaultLibrary": "#D6E2F0",
    "parameter": "#D4E2F5",
    "member": "#D6E2F0",
    "member.getter": "#C9A84C",
    "member.setter": "#C9A84C",
    "typeHint": "#6B7E9E",
    "keyword": "#80B0F0",
    "string": "#7BB896",
    "number": "#D4A047",
    "boolean": "#D4A047",
    "enumMember": "#D4A047",
    "comment": "#6B7E9E",
    "modifier": "#8892A8",
    "event": "#8892A8",
    "operator": "#8892A8",
    "label": "#8892A8",
    "macro": "#C9A84C",
    "typeParameter": "#B8862D"
  },
  "semanticHighlighting": true
}
